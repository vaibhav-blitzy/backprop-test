# Node.js Tutorial HTTP Server Backend - Git Ignore Configuration
# Backend-specific ignore patterns for the Node.js tutorial application
# Complements root .gitignore with backend-specific artifacts and files

# This file focuses on backend-generated files including:
# - Test coverage reports from Node.js built-in coverage
# - Application logs from Logger utility
# - Backend-specific environment configuration
# - Development artifacts and temporary files

# Note: Many common patterns are already covered in root .gitignore
# This file adds backend-specific patterns not covered at root level

# === Backend Node.js Dependencies ===
# Backend-specific Node.js package management artifacts

# Backend node_modules (may differ from root)
node_modules/

# Backend npm artifacts
package-lock.json
npm-debug.log*

# === Test Coverage and Reports ===
# Coverage reports and testing artifacts generated by backend tests

# Test coverage reports (generated by test-coverage.js)
coverage/
*.lcov
coverage-summary.json

# Coverage tool outputs
.nyc_output/

# Test result artifacts
test/results/

# === Application Logs and Runtime Files ===
# Runtime logs and process files generated by backend application

# Server logs (referenced in package.json scripts)
server.log
*.log
logs/

# Process runtime files
*.pid

# === Backend Environment Configuration ===
# Backend-specific environment files (keep .env.example)

# Backend environment files (may contain sensitive data)
.env
.env.local
.env.development
.env.test
.env.production

# Note: .env.example files should remain tracked for documentation

# === Temporary and Cache Files ===
# Backend-specific temporary and cache files

# Temporary processing files
tmp/
*.tmp

# Backend cache directories
.cache/

# === Development and Build Artifacts ===
# Backend build outputs and deployment artifacts

# Build output directories
dist/
build/