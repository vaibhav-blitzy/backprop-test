{
  "name": "nodejs-tutorial-hello-world",
  "version": "1.0.0",
  "description": "Educational Node.js tutorial demonstrating HTTP server creation with a single hello world endpoint using built-in modules and production-ready patterns",
  "main": "server.js",
  "type": "module",
  "private": true,
  "author": {
    "name": "Node.js Tutorial Project",
    "email": "tutorial@nodejs-examples.com",
    "url": "https://github.com/nodejs-tutorial/hello-world-server"
  },
  "license": "MIT",
  "homepage": "https://github.com/nodejs-tutorial/hello-world-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodejs-tutorial/hello-world-server.git"
  },
  "bugs": {
    "url": "https://github.com/nodejs-tutorial/hello-world-server/issues"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.5.2"
  },
  "keywords": [
    "nodejs",
    "tutorial",
    "http-server",
    "hello-world",
    "educational",
    "beginner",
    "learning",
    "web-server",
    "javascript",
    "backend",
    "api",
    "rest",
    "express-alternative",
    "built-in-modules",
    "zero-dependencies",
    "production-ready",
    "lts",
    "v22"
  ],
  "scripts": {
    "start": "node scripts/start.js",
    "dev": "node scripts/dev.js",
    "test": "node scripts/test.js",
    "test:unit": "node scripts/test.js --type=unit",
    "test:integration": "node scripts/test.js --type=integration",
    "test:e2e": "node scripts/test.js --type=e2e",
    "test:watch": "node scripts/test.js --watch",
    "test:coverage": "node scripts/test-coverage.js",
    "lint": "node scripts/lint.js",
    "clean": "node scripts/clean.js",
    "build": "node scripts/clean.js && npm test",
    "prestart": "npm run clean && npm run lint",
    "pretest": "npm run lint",
    "posttest": "npm run test:coverage",
    "prepublishOnly": "npm run build",
    "dev:watch": "node scripts/dev.js --watch",
    "dev:debug": "node scripts/dev.js --debug",
    "dev:verbose": "node scripts/dev.js --verbose",
    "dev:port": "node scripts/dev.js --port",
    "server": "node server.js",
    "server:dev": "NODE_ENV=development node server.js",
    "server:prod": "NODE_ENV=production node server.js",
    "test:unit:watch": "node scripts/test.js --type=unit --watch",
    "test:integration:watch": "node scripts/test.js --type=integration --watch",
    "test:e2e:watch": "node scripts/test.js --type=e2e --watch",
    "test:coverage:unit": "node scripts/test-coverage.js --type=unit",
    "test:coverage:integration": "node scripts/test-coverage.js --type=integration",
    "test:coverage:html": "node scripts/test-coverage.js --reporter=html",
    "test:performance": "node scripts/test.js --type=performance",
    "test:ci": "node scripts/test.js --reporter=tap",
    "lint:check": "node scripts/lint.js --check",
    "lint:fix": "node scripts/lint.js --fix",
    "format": "node scripts/lint.js --format",
    "format:check": "node scripts/lint.js --format --check",
    "validate": "npm run lint && npm run test && npm run test:coverage",
    "quality:check": "npm run lint:check && npm run test:ci",
    "clean:cache": "node scripts/clean.js --cache",
    "clean:logs": "node scripts/clean.js --logs",
    "clean:coverage": "node scripts/clean.js --coverage",
    "clean:all": "node scripts/clean.js --all",
    "reset": "npm run clean:all && npm install",
    "reinstall": "npm run clean && npm install",
    "build:prod": "NODE_ENV=production npm run build",
    "start:prod": "NODE_ENV=production npm start",
    "health:check": "node scripts/health-check.js",
    "deploy:check": "npm run build:prod && npm run health:check"
  },
  "dependencies": {},
  "devDependencies": {},
  "peerDependencies": {},
  "optionalDependencies": {},
  "bundledDependencies": []
}