# ===============================================================================
# Environment Variables Configuration Template for Node.js Tutorial HTTP Server
# ===============================================================================
#
# This file serves as a comprehensive template showing all available environment variables
# for the Node.js tutorial HTTP server application with educational examples and
# enterprise-grade configuration management patterns.
#
# USAGE INSTRUCTIONS:
# Copy this file to create your environment-specific configuration:
#   - .env.development (for local development)
#   - .env.test (for testing environments) 
#   - .env.production (for production deployment)
# Uncomment and modify the variables you need for your environment
#
# SECURITY WARNING:
# - Never commit .env files with actual values to version control
# - This .env.example file should only contain example values
# - Add your actual .env files to .gitignore
# - Never include production secrets, API keys, or sensitive data
#
# ===============================================================================

# === Core Application Configuration ===
# These variables control the fundamental application behavior and environment setup
# Used by src/backend/config/environment.js EnvironmentConfig class

# Application environment type (development, test, production)
# Must be one of: development, test, production
# Required: Yes
NODE_ENV=development
# NODE_ENV=development  # Enhanced debugging and logging
# NODE_ENV=test            # Minimal logging, optimized for testing  
# NODE_ENV=production   # Production optimizations and security

# HTTP server port number for application binding
# Valid port number between 1024-65535
# Required: No (defaults to 3000)
# Used by src/backend/config/environment.js for server port binding
PORT=3000
# PORT=3000             # Standard development port
# PORT=3001             # Test port to avoid conflicts
# PORT=8080             # Production port or from process.env.PORT

# Server hostname or IP address for binding
# Valid hostname or IP address format
# Required: No (defaults to localhost)
# Read by src/backend/config/environment.js for HTTP server hostname binding
HOST=localhost
# HOST=localhost        # Local development access only
# HOST=127.0.0.1        # Explicit localhost for testing
# HOST=0.0.0.0          # Allow external access in production


# === Server Configuration ===
# These variables control HTTP server behavior and performance characteristics
# Used by src/backend/config/server.config.js for server metadata and settings

# Server identification name for logging and HTTP headers
# Non-empty string for server identification
# Required: No (defaults to "Node.js Tutorial HTTP Server")
# Used by src/backend/config/server.config.js for server metadata
SERVER_NAME="Node.js Tutorial HTTP Server"
# SERVER_NAME="Node.js Tutorial Server (Dev)"
# SERVER_NAME="Node.js Tutorial Server (Test)"
# SERVER_NAME="Node.js Tutorial Server"

# HTTP server timeout in milliseconds
# Positive integer between 5000-300000 milliseconds
# Required: No (defaults to 30000)
# Read by src/backend/config/server.config.js for HTTP server timeout configuration
SERVER_TIMEOUT=30000
# SERVER_TIMEOUT=30000   # Generous timeout for debugging
# SERVER_TIMEOUT=5000    # Fast timeout for test execution
# SERVER_TIMEOUT=15000   # Balanced timeout for production

# Maximum concurrent connections
# Positive integer between 10-10000
# Required: No (defaults to 1000)
# Used by src/backend/config/server.config.js for connection limit configuration
MAX_CONNECTIONS=1000
# MAX_CONNECTIONS=100    # Limited connections for development
# MAX_CONNECTIONS=10     # Minimal connections for testing
# MAX_CONNECTIONS=1000   # Higher limit for production load

# Keep-alive timeout for HTTP connections in milliseconds
# Positive integer between 1000-60000 milliseconds
# Required: No (defaults to 5000)
# Read by src/backend/config/server.config.js for HTTP connection keep-alive configuration
KEEP_ALIVE_TIMEOUT=5000
# KEEP_ALIVE_TIMEOUT=5000 # Standard keep-alive for development
# KEEP_ALIVE_TIMEOUT=1000 # Fast cleanup for tests
# KEEP_ALIVE_TIMEOUT=30000 # Longer keep-alive for production


# === Logging Configuration ===
# These variables control application logging behavior and output formatting
# Used by src/backend/utils/logger.js Logger class for comprehensive logging

# Logging level for application output
# Must be one of: error, warn, info, debug, trace
# Required: No (defaults to info)
# Used by src/backend/utils/logger.js Logger class for log level filtering
LOG_LEVEL=info
# LOG_LEVEL=debug         # Comprehensive logging for development
# LOG_LEVEL=error         # Minimal logging for clean test output
# LOG_LEVEL=warn          # Production-appropriate logging level

# Enable/disable HTTP request/response logging
# Boolean value (true/false)
# Required: No (defaults to true)
# Read by src/backend/config/app.config.js for logging middleware activation
ENABLE_LOGGING=true
# ENABLE_LOGGING=true     # Enable detailed logging for development
# ENABLE_LOGGING=false    # Disable logging for clean test output
# ENABLE_LOGGING=true     # Enable logging for production monitoring


# === Feature Flags ===
# These variables enable/disable specific application features and middleware
# Used throughout the application for conditional feature activation

# Enable Cross-Origin Resource Sharing headers
# Boolean value (true/false)
# Required: No (defaults to true)
# Used by src/backend/middleware/cors-handler.js for CORS middleware activation
ENABLE_CORS=true
# ENABLE_CORS=true        # Enable CORS for development and testing
# ENABLE_CORS=false       # Disable CORS for simplified testing
# ENABLE_CORS=false       # Disable CORS for production security

# Enable security headers and middleware
# Boolean value (true/false)
# Required: No (defaults to true)
# Read by src/backend/config/app.config.js for security middleware configuration
ENABLE_SECURITY=true
# ENABLE_SECURITY=true    # Enable security headers for development
# ENABLE_SECURITY=false   # Disable security for simplified testing
# ENABLE_SECURITY=true    # Enable full security for production

# Enable performance metrics collection
# Boolean value (true/false)
# Required: No (defaults to true)
# Used by src/backend/utils/logger.js for metrics collection activation
ENABLE_METRICS=true
# ENABLE_METRICS=true     # Enable metrics for development optimization
# ENABLE_METRICS=false    # Disable metrics for faster test execution
# ENABLE_METRICS=true     # Enable metrics for production monitoring


# ===============================================================================
# ENVIRONMENT-SPECIFIC CONFIGURATION EXAMPLES
# ===============================================================================

# === Development Environment Example ===
# Example configuration for local development environment
# Copy to .env.development for development setup
#
# NODE_ENV=development
# PORT=3000
# HOST=localhost
# LOG_LEVEL=debug
# SERVER_NAME="Node.js Tutorial Server (Dev)"
# ENABLE_LOGGING=true
# ENABLE_CORS=true
# ENABLE_SECURITY=true
# ENABLE_METRICS=true
# SERVER_TIMEOUT=30000
# MAX_CONNECTIONS=100
# KEEP_ALIVE_TIMEOUT=5000

# === Test Environment Example ===
# Example configuration for test environment
# Copy to .env.test for test setup
#
# NODE_ENV=test
# PORT=3001
# HOST=127.0.0.1
# LOG_LEVEL=error
# SERVER_NAME="Node.js Tutorial Server (Test)"
# ENABLE_LOGGING=false
# ENABLE_CORS=false
# ENABLE_SECURITY=false
# ENABLE_METRICS=false
# SERVER_TIMEOUT=5000
# MAX_CONNECTIONS=10
# KEEP_ALIVE_TIMEOUT=1000

# === Production Environment Example ===
# Example configuration for production environment
# Copy to .env.production for production setup
#
# NODE_ENV=production
# PORT=8080
# HOST=0.0.0.0
# LOG_LEVEL=warn
# SERVER_NAME="Node.js Tutorial Server"
# ENABLE_LOGGING=true
# ENABLE_CORS=false
# ENABLE_SECURITY=true
# ENABLE_METRICS=true
# SERVER_TIMEOUT=15000
# MAX_CONNECTIONS=1000
# KEEP_ALIVE_TIMEOUT=30000


# ===============================================================================
# SETUP INSTRUCTIONS
# ===============================================================================

# QUICK START:
# 1. Copy this file to .env.development:
#    cp .env.example .env.development
#
# 2. Uncomment and modify variables as needed for your environment
#
# 3. Start the application:
#    npm run dev
#
# 4. The server will use your environment configuration automatically

# ENVIRONMENT SETUP:
# For Development:
# - Copy .env.example to .env.development
# - Use development-optimized settings with enhanced logging
# - Enable CORS and debugging features
#
# For Testing:
# - Copy .env.example to .env.test
# - Use test-optimized settings with minimal logging
# - Configure different port to avoid conflicts
#
# For Production:
# - Copy .env.example to .env.production
# - Use production-optimized settings with security enabled
# - Configure appropriate timeouts and connection limits


# ===============================================================================
# VALIDATION RULES AND INTEGRATION POINTS
# ===============================================================================

# ENVIRONMENT VALIDATION:
# - NODE_ENV: Must be exactly 'development', 'test', or 'production'
# - PORT: Valid port number between 1024-65535, avoid system ports
# - HOST: Valid hostname or IP address format

# PERFORMANCE VALIDATION:
# - SERVER_TIMEOUT: Between 5000-300000 milliseconds based on environment
# - MAX_CONNECTIONS: Between 10-10000 based on environment and resources
# - KEEP_ALIVE_TIMEOUT: Between 1000-60000 milliseconds

# FEATURE VALIDATION:
# - All ENABLE_* variables must be 'true' or 'false'
# - LOG_LEVEL must be error, warn, info, debug, or trace

# INTEGRATION POINTS:
# - Environment Loader: src/backend/config/environment.js (EnvironmentConfig class)
# - Server Configuration: src/backend/config/server.config.js (ServerConfig class)  
# - Application Bootstrap: src/backend/server.js (createServerInstance function)


# ===============================================================================
# TROUBLESHOOTING GUIDE
# ===============================================================================

# COMMON ISSUES:
# 1. Environment variables not loading:
#    - Ensure .env file exists and is in project root directory
#    - Check file path and NODE_ENV setting
#
# 2. Port conflicts during development:
#    - Change PORT value to available port (3001, 4000, 8080)
#    - Use 'netstat -an | grep PORT' to check port availability
#
# 3. Boolean values not working correctly:
#    - Ensure boolean values are lowercase 'true' or 'false' without quotes
#    - Check configuration validation logs for type conversion errors

# DEBUGGING STEPS:
# 1. Verify .env file exists in correct location
# 2. Check file permissions and readability
# 3. Validate environment variable syntax and format
# 4. Test with default values to isolate configuration issues
# 5. Check application startup logs for configuration errors
# 6. Use debug logging to verify variable values are loaded correctly


